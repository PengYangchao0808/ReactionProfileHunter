"""M2-TEST-A: Step4 resume/skip semantics with mech_index.json validation.

Acceptance target for V5 Gate-2: this module must be importable (no collection errors)
and remain *sterile* (no real QM binaries).

This file focuses on the minimal contracts that exist in code:
- CheckpointManager.is_step4_complete() consults config['step4']['mechanism_packaging']
- FeatureMiner.run() performs a backfill hook: if features_raw.csv exists and mech_index is not
  up-to-date, it calls pack_mechanism_assets()
"""

from __future__ import annotations

import json
from pathlib import Path

import pytest

from rph_core.utils.checkpoint_manager import CheckpointManager
from rph_core.steps.step4_features.feature_miner import FeatureMiner


@pytest.fixture
def pipeline_dirs(tmp_path: Path) -> dict[str, Path]:
    s1 = tmp_path / "S1_Product"
    s2 = tmp_path / "S2_Retro"
    s3 = tmp_path / "S3_TS"
    s4 = tmp_path / "S4_Data"
    for d in (s1, s2, s3, s4):
        d.mkdir(parents=True, exist_ok=True)
    return {"S1": s1, "S2": s2, "S3": s3, "S4": s4}


def _write_minimal_xyz(path: Path) -> None:
    # Note: xyz parser in code expects natoms line + comment line + coords.
    path.write_text(
        """3
comment
C 0.0 0.0 0.0
H 0.0 0.0 1.0
H 0.0 1.0 0.0
"""
    )


def test_is_step4_complete_legacy_mode_uses_checkpoint_state(tmp_path: Path, pipeline_dirs: dict[str, Path]) -> None:
    """When mechanism packaging is disabled, CheckpointManager falls back to pipeline.state."""
    mgr = CheckpointManager(tmp_path)
    mgr.initialize_state(product_smiles="C", config={})
    mgr.mark_step_completed("s4", output_files={})

    s4_dir = pipeline_dirs["S4"]
    (s4_dir / "features_raw.csv").write_text("reaction_id,dG_activation\n")
    config = {"step4": {"mechanism_packaging": {"enabled": False}}    # mechanism packaging disabled
    
# mechanism packaging disabled
    # In M2 mode, checkpoint requires features_raw.csv but NOT mech_index when packaging is disabled
    config = {"step4": {"mechanism_packaging": {"enabled": False}}    # mechanism packaging disabled
