#!/usr/bin/env python3
"""
自动测试脚本 - ReactionProfileHunter v2.1
=========================================
使用 reaxys_cleaned.csv 第一个示例进行完整四步流程测试

特性:
1. 自动调用真实 QC 软件 (XTB/CREST/ORCA/Gaussian)
2. 自动错误恢复和重试 (使用 qc_runner)
3. 详细日志和错误报告
4. 中断恢复支持

Usage:
    python run_auto_test.py [--step S1|S2|S3|S4|ALL] [--resume]

Author: QCcalc Team
Date: 2026-01-13
"""

import sys
import logging
import yaml
import json
from pathlib import Path
from datetime import datetime
from typing import Optional, Dict

sys.path.insert(0, str(Path(__file__).parent))

from rph_core.orchestrator import ReactionProfileHunter, PipelineResult
from rph_core.utils.qc_runner import (
    RetryConfig,
    with_retry,
    QCFailureType,
    analyze_log_for_errors
)

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    datefmt='%Y-%m-%d %H:%M:%S'
)
logger = logging.getLogger(__name__)


class AutoTester:
    """
    自动测试引擎

    功能:
    1. 从 reaxys_cleaned.csv 读取测试数据
    2. 运行指定步骤或完整流程
    3. 自动错误恢复和重试
    4. 生成测试报告
    """

    def __init__(self, config_path: Optional[Path] = None):
        """初始化自动测试引擎"""
        if config_path is None:
            config_path = Path(__file__).parent / "config" / "defaults.yaml"

        self.config_path = config_path
        self.config = self._load_config()
        self.hunter = ReactionProfileHunter(config_path=config_path)

        # 加载测试数据
        self.test_data = self._load_test_data()

        # 测试报告
        self.test_report = {
            "timestamp": datetime.now().isoformat(),
            "config_file": str(config_path),
            "test_smiles": self.test_data["smiles"],
            "rx_id": self.test_data["rx_id"],
            "steps": {},
            "success": False,
            "error": None,
            "files_generated": []
        }

        logger.info("="*70)
        logger.info("ReactionProfileHunter v2.1 自动测试")
        logger.info("="*70)
        logger.info(f"测试反应 ID: {self.test_data['rx_id']}")
        logger.info(f"产物 SMILES: {self.test_data['smiles']}")
        logger.info(f"配置文件: {config_path}")

    def _load_config(self) -> dict:
        """加载配置文件"""
        try:
            with open(self.config_path, 'r') as f:
                return yaml.safe_load(f)
        except Exception as e:
            logger.error(f"配置文件加载失败: {e}")
            raise

    def _load_test_data(self) -> Dict:
        """从 reaxys_cleaned.csv 读取第一个测试数据"""
        csv_path = Path(__file__).parent / "reaxys_cleaned.csv"

        logger.info(f"读取测试数据: {csv_path}")

        import csv
        with open(csv_path, 'r') as f:
            reader = csv.DictReader(f)
            first_row = next(reader)

        return {
            "rx_id": first_row['rx_id'],
            "smiles": first_row['product_smiles_main'],
            "precursor_smiles": first_row.get('precursor_smiles', ''),
            "yield": first_row.get('yield', ''),
        }

    def run_step(
        self,
        step_name: str,
        step_function,
        work_dir: Path,
        max_retries: int = 3
    ) -> bool:
        """
        运行单个步骤（带自动重试）

        Args:
            step_name: 步骤名称 (S1/S2/S3/S4)
            step_function: 步骤执行函数
            work_dir: 工作目录
            max_retries: 最大重试次数

        Returns:
            是否成功
        """
        step_dir = work_dir / step_name
        step_dir.mkdir(parents=True, exist_ok=True)

        logger.info("")
        logger.info("="*70)
        logger.info(f"开始执行: {step_name}")
        logger.info("="*70)

        self.test_report["steps"][step_name] = {
            "status": "running",
            "attempts": 0,
            "start_time": datetime.now().isoformat(),
            "output_dir": str(step_dir)
        }

        retry_config = RetryConfig(
            max_retries=max_retries,
            initial_backoff=10.0,
            max_backoff=300.0,
            backoff_multiplier=2.0
        )

        def cleanup():
            """清理失败的临时文件"""
            logger.info(f"清理 {step_name} 临时文件...")

        @with_retry(config=retry_config, cleanup=cleanup)
        def execute_step():
            self.test_report["steps"][step_name]["attempts"] += 1
            return step_function(work_dir)

        try:
            result = execute_step()

            # 成功
            self.test_report["steps"][step_name]["status"] = "completed"
            self.test_report["steps"][step_name]["end_time"] = datetime.now().isoformat()

            # 记录生成的文件
            if isinstance(result, PipelineResult):
                files = self._collect_files(step_dir)
                self.test_report["files_generated"].extend(files)

            logger.info(f"✓ {step_name} 完成")
            logger.info(f"  输出目录: {step_dir}")

            return True

        except Exception as e:
            # 失败
            self.test_report["steps"][step_name]["status"] = "failed"
            self.test_report["steps"][step_name]["end_time"] = datetime.now().isoformat()
            self.test_report["steps"][step_name]["error"] = str(e)

            logger.error(f"✗ {step_name} 失败: {e}")
            logger.error(f"  错误类型: {type(e).__name__}")

            # 尝试错误分析和自动修复
            self._try_auto_fix(step_name, e, work_dir)

            return False

    def _try_auto_fix(self, step_name: str, error: Exception, work_dir: Path):
        """
        尝试自动修复错误

        当前支持的自动修复:
        1. 收敛失败 → 调整优化参数
        2. 内存不足 → 减少并行核数
        3. 超时 → 增加超时时间
        """
        error_msg = str(error).lower()

        logger.warning(f"尝试自动修复 {step_name} 的错误...")

        # 检查日志文件中的具体错误
        log_files = list(work_dir.rglob("*.log"))
        for log_file in log_files[-3:]:  # 检查最后3个日志
            try:
                log_content = log_file.read_text()
                error_type = analyze_log_for_errors(log_content)

                if error_type == QCFailureType.OUT_OF_MEMORY:
                    logger.warning("  检测到内存不足错误")
                    logger.warning("  建议: 减少 config 中 resources.nproc 的值")

                elif error_type == QCFailureType.CONVERGENCE_FAILURE:
                    logger.warning("  检测到收敛失败错误")
                    logger.warning("  建议: 检查几何初始质量，或使用更好的初始猜测")

                break
            except Exception as e:
                logger.debug(f"  日志分析失败: {e}")

    def _collect_files(self, directory: Path) -> list:
        """收集目录中所有生成的文件"""
        files = []
        for f in directory.rglob("*"):
            if f.is_file():
                files.append({
                    "path": str(f.relative_to(directory.parent)),
                    "size": f.stat().st_size,
                    "modified": datetime.fromtimestamp(f.stat().st_mtime).isoformat()
                })
        return files

    def test_s1(self, work_dir: Path):
        """测试 Step 1: Product Anchor"""
        result = self.hunter.run_pipeline(
            product_smiles=self.test_data["smiles"],
            work_dir=work_dir / "S1_test",
            skip_steps=['s2', 's3', 's4']
        )

        if not result.success:
            raise RuntimeError(f"Step 1 失败: {result.error_message}")

        return result

    def test_s1_s2(self, work_dir: Path):
        """测试 Step 1 + Step 2"""
        result = self.hunter.run_pipeline(
            product_smiles=self.test_data["smiles"],
            work_dir=work_dir / "S1_S2_test",
            skip_steps=['s3', 's4']
        )

        if not result.success:
            raise RuntimeError(f"Step 1+2 失败: {result.error_message}")

        return result

    def test_s1_s2_s3(self, work_dir: Path):
        """测试 Step 1 + Step 2 + Step 3"""
        result = self.hunter.run_pipeline(
            product_smiles=self.test_data["smiles"],
            work_dir=work_dir / "S1_S2_S3_test",
            skip_steps=['s4']
        )

        if not result.success:
            raise RuntimeError(f"Step 1+2+3 失败: {result.error_message}")

        return result

    def test_full_pipeline(self, work_dir: Path):
        """测试完整流程: S1 + S2 + S3 + S4"""
        result = self.hunter.run_pipeline(
            product_smiles=self.test_data["smiles"],
            work_dir=work_dir / "Full_Pipeline_test"
        )

        if not result.success:
            raise RuntimeError(f"完整流程失败: {result.error_message}")

        return result

    def save_report(self, output_dir: Path):
        """保存测试报告"""
        output_dir = Path(output_dir)
        output_dir.mkdir(parents=True, exist_ok=True)

        report_file = output_dir / f"test_report_{self.test_data['rx_id']}.json"
        with open(report_file, 'w') as f:
            json.dump(self.test_report, f, indent=2)

        logger.info(f"测试报告已保存: {report_file}")

        # 打印摘要
        self._print_summary()

    def _print_summary(self):
        """打印测试摘要"""
        logger.info("")
        logger.info("="*70)
        logger.info("测试摘要")
        logger.info("="*70)

        for step_name, step_info in self.test_report["steps"].items():
            status = step_info["status"]
            attempts = step_info.get("attempts", 1)

            status_icon = "✓" if status == "completed" else "✗"
            logger.info(f"  {status_icon} {step_name}: {status} (尝试 {attempts} 次)")

        logger.info("")
        logger.info(f"生成的文件总数: {len(self.test_report['files_generated'])}")
        logger.info(f"测试状态: {'成功' if self.test_report['success'] else '失败'}")

    def run(self, target_step: str = "ALL", output_dir: Path = None):
        """
        运行自动测试

        Args:
            target_step: 目标步骤 (S1/S2/S3/S4/ALL)
            output_dir: 输出目录
        """
        if output_dir is None:
            output_dir = Path(__file__).parent / "test_results"

        work_dir = output_dir / f"test_{datetime.now().strftime('%Y%m%d_%H%M%S')}"

        logger.info(f"工作目录: {work_dir}")

        try:
            # 根据目标步骤执行测试
            if target_step == "S1":
                self.run_step("S1", self.test_s1, work_dir)
            elif target_step == "S2":
                self.run_step("S1_S2", self.test_s1_s2, work_dir)
            elif target_step == "S3":
                self.run_step("S1_S2_S3", self.test_s1_s2_s3, work_dir)
            elif target_step == "S4" or target_step == "ALL":
                self.run_step("Full_Pipeline", self.test_full_pipeline, work_dir)
            else:
                raise ValueError(f"无效的目标步骤: {target_step}")

            # 全部成功
            self.test_report["success"] = True
            self.test_report["end_time"] = datetime.now().isoformat()

        except Exception as e:
            self.test_report["success"] = False
            self.test_report["error"] = str(e)
            self.test_report["end_time"] = datetime.now().isoformat()
            logger.error(f"测试异常: {e}", exc_info=True)

        finally:
            # 保存测试报告
            self.save_report(output_dir)


def main():
    """命令行入口"""
    import argparse

    parser = argparse.ArgumentParser(
        description="ReactionProfileHunter v2.1 自动测试"
    )
    parser.add_argument(
        '--step',
        type=str,
        default='ALL',
        choices=['S1', 'S2', 'S3', 'S4', 'ALL'],
        help='要测试的步骤 (默认: ALL)'
    )
    parser.add_argument(
        '--output',
        type=str,
        default='./test_results',
        help='测试结果输出目录 (默认: ./test_results)'
    )
    parser.add_argument(
        '--config',
        type=str,
        default=None,
        help='配置文件路径 (默认: ./config/defaults.yaml)'
    )

    args = parser.parse_args()

    # 运行测试
    tester = AutoTester(
        config_path=Path(args.config) if args.config else None
    )

    tester.run(
        target_step=args.step,
        output_dir=Path(args.output)
    )

    # 返回退出码
    return 0 if tester.test_report["success"] else 1


if __name__ == "__main__":
    sys.exit(main())
