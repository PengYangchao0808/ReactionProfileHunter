    def collect_hirshfeld_outputs(self, output_dir: Path, jobname: str = "gaussian") -> Dict[str, Path]:
        """
        Mock Hirshfeld output collection - generate fake .json files.

        Args:
            output_dir: Output directory for Hirshfeld JSON files
            jobname: Job name for file naming

        Returns:
            Dictionary mapping QC keys to fake Hirsheld JSON file paths
        """
        from typing import Dict

        hirshfeld_files = {}
