class TaskKind(Enum):
    """Enumeration of QC task types for resource selection."""
    OPTIMIZATION = "optimization"
    SINGLE_POINT = "single_point"
    FREQUENCY = "frequency"
    TS_OPTIMIZATION = "ts_optimization"
    IRC = "irc"
    NBO = "nbo"


    NBO_WHITELIST = {'.47', '.nbo', '.3', '.31', '.41'}

    NMR_WHITELIST = {'.nmrdat', '.shieldings.dat', '.nmrout'}

    def collect_nmr_outputs(output_dir: Path, jobname: str) -> Dict[str, Path]:
        """
        M3-4-3: Collect NMR output files using whitelist-based pattern matching.

        Args:
            output_dir: Base output directory
            jobname: Job name used to search for NMR files

        Returns:
            Dict mapping file extensions to absolute paths
            Only returns files whose extensions are in NMR_WHITELIST.
        """
        output_dir = Path(output_dir).resolve()

        nmr_files = {}

        for ext in NMR_WHITELIST:
            glob_pattern = f"{jobname}{ext}"
            matching_files = list(output_dir.glob(glob_pattern))

            if matching_files:
                if len(matching_files) > 1:
                    matching_files.sort(key=lambda f: f.stat().st_mtime, reverse=True)
                    logger.warning(
                        f"Multiple files found for {jobname}{ext}: {[f.name for f in matching_files]}. "
                        f"Using most recent: {matching_files[0].name}"
                    )

                nmr_files[ext] = matching_files[0].resolve()
                logger.debug(f"Found NMR file: {nmr_files[ext]}")

        if not nmr_files:
            logger.warning(f"No NMR files found in {output_dir} with whitelist {NMR_WHITELIST}")

        return nmr_files

    def parse_hirshfeld_charges(log_path: Path) -> Optional[Dict[int, float]]:
        """
        M3-4-4: Parse Hirshfeld charges from Gaussian output log (regex-based, minimal).

        Args:
            log_path: Path to Gaussian .log file

        Returns:
            Dictionary mapping atom indices to charges, or None if not found
            Uses regex pattern to find Hirshfeld charge section, allowing
            minimal viable parsing (can return None).

        Note:
            - Hirshfeld output format in Gaussian logs varies significantly between versions
            - This implementation uses a flexible regex to find charge blocks
            - Returns None on parsing failure (graceful degradation)
        """
        try:
            with open(log_path, 'r', encoding='utf-8', errors='replace') as f:
                log_content = f.read()

            pattern = r'Hirshfeld\s+charges\s*.*?\n(?:=|\s+)\n((?:[+-]?\d+\.\d+\s+)+)'
            match = re.search(pattern, log_content)

            if not match:
                logger.warning(f"Hirshfeld charges not found in {log_path}")
                return None

            charges_str = match.group(1).strip()
            charge_lines = charges_str.split()

            charges = {}
            for line in charge_lines:
                parts = line.split()
                for part in parts:
                    match = re.search(r'([+-]?\d+\.\d+)', part)
                    if match:
                        charge_value = float(match.group(1))
                        charges[int(match.start())] = charge_value

            return charges

        except Exception as e:
            logger.error(f"Failed to parse Hirshfeld charges from {log_path}: {e}")
            return None


    def parse_hirsheld_charges(log_path: Path) -> Optional[Dict[int, float]]:
        """
        DEPRECATED: Use parse_hirshfeld_charges instead (correct spelling).

        This function is provided for backward compatibility only.
        Will be removed in a future version.

        Args:
            log_path: Path to Gaussian .log file

        Returns:
            Dictionary mapping atom indices to charges, or None if not found
        """
        import warnings
        warnings.warn(
            "parse_hirsheld_charges is deprecated. Use parse_hirshfeld_charges instead.",
            DeprecationWarning,
            stacklevel=2
        )
        return parse_hirshfeld_charges(log_path)


def parse_hirshfeld_charges(log_path: Path) -> Optional[Dict[int, float]]:
    """
    M3-4-4: Parse Hirshfeld charges from Gaussian output log (regex-based, minimal).

    Args:
        log_path: Path to Gaussian .log file

    Returns:
            Dictionary mapping atom indices to charges, or None if not found
    Uses regex pattern to find Hirshfeld charge section, allowing
            minimal viable parsing (can return None).

    Note:
            - Hirshfeld output format in Gaussian logs varies significantly between versions
            - This implementation uses a flexible regex to find charge blocks
            - Returns None on parsing failure (graceful degradation)
        """
    try:
        with open(log_path, 'r', encoding='utf-8', errors='replace') as f:
            log_content = f.read()

            pattern = r'Hirshfeld\s+charges\s*.*?\n(?:=|\s+)\n((?:[+-]?\d+\.\d+\s+)+)'
            match = re.search(pattern, log_content)

            if not match:
                logger.warning(f"Hirshfeld charges not found in {log_path}")
                return None

            charges_str = match.group(1).strip()
            charge_lines = charges_str.split()
            charges = {}

            for line in charge_lines:
                parts = line.split()
                for part in parts:
                    match = re.search(r'([+-]?\d+\.\d+\s+)+)', part)
                    if match:
                        charge_value = float(match.group(1))
                        charges[int(match.start())] = charge_value

            return charges

    except Exception as e:
        logger.error(f"Failed to parse Hirshfeld charges from {log_path}: {e}")
        return None


    def collect_nmr_outputs(self, output_dir: Path, jobname: str = "gaussian") -> List[Path]:
        """
        Mock NMR output collection - generate fake .nmrdat files.

