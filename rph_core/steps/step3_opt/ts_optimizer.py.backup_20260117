@dataclass
class SPMatrixReport:
    e_ts: float = 0.0
    e_reactant: float = 0.0
    e_product: float = 0.0
    e_reactant_l2: float = 0.0
    e_product_l2: float = 0.0
    e_ts_final: Optional[float] = None
    e_frag_a_ts: Optional[float] = None
    e_frag_b_ts: Optional[float] = None
    e_frag_a_relaxed: Optional[float] = None
    e_frag_b_relaxed: Optional[float] = None
    method: str = "Berny"
    solvent: str = "acetone"
    g_ts: Optional[float] = None
    h_ts: Optional[float] = None
    g_reactant: Optional[float] = None
    h_reactant: Optional[float] = None
    g_product: Optional[float] = None
    h_product: Optional[float] = None

    def get_activation_energy(self) -> float:
        if self.e_ts is None or self.e_reactant is None:
            return 0.0
        return (self.e_ts - self.e_reactant) * 627.509
    def get_reaction_energy(self) -> float:
        if self.e_product is None or self.e_reactant is None:
            return 0.0
        return (self.e_product - self.e_reactant) * 627.509

